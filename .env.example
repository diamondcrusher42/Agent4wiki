# Agent4 — Environment Template
# Copy to .env and fill in your values. Never commit .env.

# ── Telegram (primary Bridge channel — REQUIRED) ──────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Email (Bridge fallback 1 — AgentMail) ─────────────────────────────────────
# Get API key at: https://agentmail.to
# Inbox format: yourusername@agentmail.to
AGENTMAIL_API_KEY=your_agentmail_api_key
AGENTMAIL_INBOX_ID=yourusername@agentmail.to
PERSONAL_EMAIL=you@email.com              # where notifications are delivered to

# ── Discord (Bridge fallback 2 + parallel for critical alerts) ────────────────
# Create webhook: Discord server → Channel Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_id/your_token

# ── Slack (Bridge fallback 3) ─────────────────────────────────────────────────
# Create webhook: Slack App → Incoming Webhooks → Add New Webhook to Workspace
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ── SMS via Twilio (last resort — costs per message, critical alerts only) ────
# Sign up at: https://twilio.com — free trial covers ~15 SMS
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890             # your Twilio number
TWILIO_TO_NUMBER=+0987654321               # your personal number

# ── AI APIs ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...          # optional — for alternative routing
GROQ_API_KEY=gsk_...           # optional — bulk/free tier

# ── MemPalace MCP ─────────────────────────────────────────────────────────────
MEMPALACE_URL=http://localhost:3001
MEMPALACE_API_KEY=your_key_here

# ── Keychain ──────────────────────────────────────────────────────────────────
KEYCHAIN_MASTER_VAULT=./state/keychain/master.vault
KEYCHAIN_PASSPHRASE=your_passphrase_here

# ── Clone Execution ───────────────────────────────────────────────────────────
AGENT_BASE_DIR=/path/to/this/repo       # absolute path to repo root
MAX_CLONE_RETRIES=3
CLONE_TIMEOUT_MINUTES=30
ALLOWED_WORKTREE_PATH=./state/worktrees
